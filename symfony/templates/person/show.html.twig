{% extends 'base.html.twig' %}

{% block title %}Person{% endblock %}

{% block body %}
    <h1>Person</h1>

    <p>{% if person.gender != 'Autre' %}{{ person.gender }}{% endif %} {{ person.firstname }} {{ person.lastname }}</p>
    <p>{% if person.gender == 'Madame' %}
        Née
        {% elseif person.gender == 'Monsieur' %}
        Né
        {% else %}
        Né(e)
        {% endif %}
        le {{ person.birthday ? person.birthday|date('d F Y') : '' }}</p>

    <a href="{{ path('person_index') }}">back to list</a>

    <a href="{{ path('person_edit', {'id': person.id}) }}">edit</a>

    {{ include('person/_delete_form.html.twig') }}
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Person{% endblock %}

{% block body %}
    <h1>Person</h1>

    <p {% if person.hasCovid %}style="color:red"{% endif %}>{% if person.gender != 'Autre' %}{{ person.gender }}{% endif %} {{ person.firstname }} {{ person.lastname }}</p>
    <p>{% if person.gender == 'Madame' %}
        Née
        {% elseif person.gender == 'Monsieur' %}
        Né
        {% else %}
        Né(e)
        {% endif %}
        le {{ person.birthday ? person.birthday|date('d F Y') : '' }}</p>

    <p>Lieux visités</p>
    <ul>
        {% for visitedLocation in person.visitedLocations %}
            <li>{{ visitedLocation.location.name }} {{ visitedLocation.visitedAt|date('d F Y H:i:s') }}</li>
        {% endfor %}
    </ul>

    {% if not person.hasCovid %}
        <p>Personnes qui on rendu cas contact cette personne</p>
        <ul>
            {% for visitedLocation in person.visitedLocations %}
                {% for people in visitedLocation.location.peopleWhoVisited %}
                    {% set dateDiff = visitedLocation.visitedAt.diff(people.visitedAt) %}
                    {% if people.user.hasCovid and dateDiff.h < 3 and dateDiff.days == 0 and dateDiff.y == 0 and dateDiff.m == 0 %}
                        <li>{{ people.user.firstname }} {{ people.user.lastname }}</li>
                    {% endif %}
                {% endfor %}
            {% endfor %}
        </ul>
    {% else %}
        <p>Personnes que cette personne a rendu cas contact</p>
        <ul>
            {% for visitedLocation in person.visitedLocations %}
                {% for people in visitedLocation.location.peopleWhoVisited %}
                    {% set dateDiff = visitedLocation.visitedAt.diff(people.visitedAt) %}
                    {% if not people.user.hasCovid and dateDiff.h < 3 and dateDiff.days == 0 and dateDiff.y == 0 and dateDiff.m == 0 %}
                        <li>{{ people.user.firstname }} {{ people.user.lastname }}</li>
                    {% endif %}
                {% endfor %}
            {% endfor %}
        </ul>
    {% endif %}

    <a href="{{ path('person_index') }}">back to list</a>

    <a href="{{ path('person_edit', {'id': person.id}) }}">edit</a>

    {{ include('person/_delete_form.html.twig') }}
{% endblock %}
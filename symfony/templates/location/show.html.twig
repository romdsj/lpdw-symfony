{% extends 'base.html.twig' %}

{% block title %}Location{% endblock %}

{% block body %}
    <h1>Location</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ location.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ location.name }}</td>
            </tr>
            <tr>
                <th>Address</th>
                <td>{{ location.address }}</td>
            </tr>
            <tr>
                <th>MaxNumberOfPersons</th>
                <td>{{ location.maxNumberOfPersons }}</td>
            </tr>
        </tbody>
    </table>

    <h2>Personnes ayant visitées et ayant le Covid</h2>
    <ul>
        {% for people in location.peopleWhoVisited %}
            {% if people.person.hasCovid %}
                <li>{{ people.person.firstname }} {{ people.person.lastname }}</li>
            {% endif %}
        {% endfor %}
    </ul>

    <a href="{{ path('location_index') }}">back to list</a>

    <a href="{{ path('location_edit', {'id': location.id}) }}">edit</a>

    {{ include('location/_delete_form.html.twig') }}
{% endblock %}
